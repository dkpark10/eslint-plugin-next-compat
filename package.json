{
  "name": "eslint-plugin-next-compat",
  "version": "0.0.1",
  "description": "ESLint plugin for browser compatibility checking in Next.js App Router client components",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "next",
    "nextjs",
    "compat",
    "browser-compatibility"
  ],
  "author": "dkpark10",
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "dependencies": {
    "dependency-tree": "^11.4.0",
    "eslint-plugin-compat": "^6.0.0",
    "glob": "^13.0.6",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
